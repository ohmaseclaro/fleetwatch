{
  "name": "@ohmaseclaro/fleetwatch",
  "version": "0.1.7",
  "type": "module",
  "description": "Watch every Claude Code, Cowork, and Cursor session from your phone — multi-provider agent observability with live updates over LAN or ngrok.",
  "keywords": [
    "claude",
    "claude-code",
    "cursor",
    "agent",
    "observability",
    "monitor",
    "watcher",
    "cli",
    "pwa",
    "mobile"
  ],
  "author": "Augusto Claro",
  "license": "MIT",
  "homepage": "https://github.com/ohmaseclaro/fleetwatch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohmaseclaro/fleetwatch.git"
  },
  "bugs": {
    "url": "https://github.com/ohmaseclaro/fleetwatch/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/server/**/*.js",
    "dist/server/**/*.d.ts",
    "dist/web/**/*",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "bin": {
    "fleetwatch": "./dist/server/index.js"
  },
  "scripts": {
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server/index.js",
    "go": "npm run build && npm start",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@ngrok/ngrok": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
